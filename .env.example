# Supabase Configuration
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Supabase Server-Side (available at runtime in serverless functions)
SUPABASE_URL=your-project-url
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-service-role-key

# Pinterest OAuth
PINTEREST_APP_ID=your-app-id
PINTEREST_APP_SECRET=your-app-secret
PINTEREST_REDIRECT_URI=http://localhost:3000/auth/pinterest/callback

# Trigger.dev
TRIGGER_SECRET_KEY=tr_dev_xxxxx

# Feature flags for Trigger.dev migration
USE_TRIGGER_METADATA=false
USE_TRIGGER_SCRAPING=false
